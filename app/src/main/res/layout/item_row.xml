<!-- res/layout/item_row.xml -->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Item Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical">

        <!-- Item Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <!-- Add a FrameLayout to hold the TextView with strike-through -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/nameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Item Name"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:maxLines="1"
                    android:fontFamily="@font/nuto"
                    android:ellipsize="end"
                    android:layout_marginBottom="4dp"
                    android:textStyle="bold"
                    android:autoLink="web"
                    android:linksClickable="false"
                    android:textColorLink="#333333"
                    android:textColorHighlight="#333333"
                    android:textIsSelectable="false" />



                <!-- Strike-through View (Initially Invisible) -->
                <View
                    android:id="@+id/strikeThroughView"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_horizontal"
                    android:background="#333333"
                    android:visibility="invisible" />
            </FrameLayout>

            <TextView
                android:id="@+id/priceTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Price"
                android:textColor="#666666"
                android:textSize="14sp"
                android:maxLines="1"
                android:fontFamily="@font/nuto"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/noteTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Note"
                android:alpha="0.7"
                android:textSize="14sp"
                android:maxLines="1"
                android:fontFamily="@font/nuto"
                android:ellipsize="end"
                android:layout_marginBottom="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- CheckBox -->
    <CheckBox
        android:id="@+id/checkBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true" />

    <!-- TextView for the purchase message (Initially Invisible) -->
    <TextView
        android:id="@+id/purchaseMessageTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="purchased"
        android:textColor="#FF0000"
        android:textSize="14sp"
        android:maxLines="1"
        android:fontFamily="@font/nuto"
        android:ellipsize="end"
        android:layout_marginStart="8dp"
        android:layout_toLeftOf="@+id/checkBox"
        android:visibility="gone" />
</RelativeLayout>